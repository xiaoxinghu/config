# macOS-only packages. Cross-platform CLI tools live in mise
# (see shared/.config/mise/config.toml) and zsh plugins/prompt in antidote
# (see shared/.config/zsh/.zsh_plugins.txt). Keep here only what those can't
# manage: mise itself, system tools, and GUI apps.

tap "d12frosted/emacs-plus", trusted: true

# mise (installs the cross-platform tools; via curl on Linux)
brew "mise"

# system tools
brew "git"
brew "tmux"
brew "stow"
brew "pass"

# GUI apps + fonts
cask "ghostty"
cask "leader-key"
cask "rectangle"
cask "emacs-plus-app"
cask "resilio-sync"
cask "font-jetbrains-mono-nerd-font"
cask "font-hack-nerd-font"

# built from source (no prebuilt arm64 binary); pairs with emacs above
cargo "emacs-lsp-booster"
