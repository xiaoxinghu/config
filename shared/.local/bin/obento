#!/usr/bin/env bash
# obento 🍱 — manage this dotfiles/tools repo.
#
#   obento update        git pull + re-run setup.sh (aborts on conflicts)
#   obento add <path>    move a config into the current platform and stow it
#
# Finds the repo via $OBENTO_PATH (set by setup.sh); falls back to resolving
# this script's own location, since it's stowed from <repo>/shared/.local/bin.
set -euo pipefail

resolve_repo() {
  if [[ -n "${OBENTO_PATH:-}" ]]; then
    printf '%s\n' "$OBENTO_PATH"
    return
  fi
  local src="${BASH_SOURCE[0]}" dir
  while [[ -L "$src" ]]; do
    dir="$(cd "$(dirname "$src")" && pwd)"
    src="$(readlink "$src")"
    [[ "$src" != /* ]] && src="$dir/$src"
  done
  # <repo>/shared/.local/bin/obento -> up three dirs is <repo>
  (cd "$(dirname "$src")/../../.." && pwd)
}

platform() {
  case "$(uname -s)" in
    Darwin) echo macos ;;
    Linux)  echo linux ;;
    *) echo "obento: unsupported OS: $(uname -s)" >&2; exit 1 ;;
  esac
}

REPO="$(resolve_repo)"

cmd_update() {
  echo "Updating obento in $REPO..."
  git -C "$REPO" pull --ff-only ||
    { echo "obento: git pull failed (conflicts/dirty tree?). Aborting." >&2; exit 1; }
  "$REPO/setup.sh"
}

cmd_add() {
  local target="${1:-}"
  [[ -n "$target" ]] || { echo "usage: obento add <path>" >&2; exit 1; }

  # Expand a leading ~ (in case the path was quoted) and make it absolute.
  [[ "$target" == "~/"* ]] && target="$HOME/${target#"~/"}"
  target="$(cd "$(dirname "$target")" && pwd)/$(basename "$target")"
  [[ -e "$target" ]] || { echo "obento: no such path: $target" >&2; exit 1; }
  [[ -L "$target" ]] && { echo "obento: already a symlink, skipping: $target"; exit 0; }

  # Must live under $HOME so stow can symlink it back there.
  case "$target" in
    "$HOME"/*) ;;
    *) echo "obento: path must be under \$HOME: $target" >&2; exit 1 ;;
  esac

  local rel="${target#"$HOME"/}"
  local plat dest
  plat="$(platform)"
  dest="$REPO/$plat/$rel"

  echo "Adding $rel -> $plat"
  mkdir -p "$(dirname "$dest")"
  mv "$target" "$dest"
  stow --dir="$REPO" --target="$HOME" --restow --verbose "$plat"
}

case "${1:-}" in
  update) shift; cmd_update "$@" ;;
  add)    shift; cmd_add "$@" ;;
  *) echo "usage: obento {update|add <path>}" >&2; exit 1 ;;
esac
